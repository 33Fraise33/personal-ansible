http:
  services:
{% for rule in traefik_custom_rules %}
    {{ rule.name }}:
        loadBalancer:
          servers:
            - url: "{{ rule.target }}"
{% endfor %}
  routers:
{% for rule in traefik_custom_rules %}
    {{ rule.name }}:
        rule: "Host(`{{ rule.name }}.frai.se`)"
        service: "{{ rule.name }}"
        tls:
          certResolver: le
          domains:
            - main: "*.frai.se"
{% endfor %}
  middlewares:
    auth-unitix:
      forwardAuth:
        maxBodySize: 1048576
        maxResponseBodySize: 1048576
        address: "https://auth.unitix.be/api/authz/forward-auth"
        trustForwardHeader: true
        authResponseHeaders:
          - "Remote-User"
          - "Remote-Groups"
          - "Remote-Name"
          - "Remote-Email"
    auth-fraise:
      forwardAuth:
        maxBodySize: 1048576
        maxResponseBodySize: 1048576
        address: "https://auth.frai.se/api/authz/forward-auth"
        trustForwardHeader: true
        authResponseHeaders:
          - "Remote-User"
          - "Remote-Groups"
          - "Remote-Name"
          - "Remote-Email"
    corsheaders:
      headers:
        accessControlAllowMethods:
          - GET
          - OPTIONS
          - PUT
        accessControlAllowHeaders: "*"
        accessControlAllowOriginList:
          - https://frai.se

